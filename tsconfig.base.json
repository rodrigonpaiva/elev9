{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "node16",
    "target": "ES2022",
    "lib": ["ES2022"],
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node", "jest"],
    "baseUrl": ".",
    "paths": {
      "@elev9/api-client": ["packages/api-client/src/index.ts"],
      "@elev9/api-client/*": ["packages/api-client/src/*"],
      "@elev9/ui": ["packages/ui/src/index.ts"],
      "@elev9/ui/*": ["packages/ui/src/*"],
      "@elev9/types": ["packages/types/src/index.ts"],
      "@elev9/types/*": ["packages/types/src/*"]
    }
  }
}
