{
  "name": "elev9-coach-api",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "description": "Elev9 Coach MVP backend",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nx run-many -t build -p api,types,api-client,ui --outputStyle=stream",
    "start": "nx run api:start --outputStyle=stream",
    "start:dev": "nx run api:start:dev --outputStyle=stream",
    "start:prod": "nx run api:start --outputStyle=stream",
    "mobile:start": "nx start mobile --outputStyle=stream",
    "mobile:android": "nx run mobile:run-android --outputStyle=stream",
    "mobile:ios": "nx run mobile:run-ios --outputStyle=stream",
    "test": "nx test api --outputStyle=stream",
    "test:watch": "nx run api:test:watch --outputStyle=stream",
    "test:e2e": "nx run api:test:e2e --outputStyle=stream"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "expo": "~54.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.15.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "scheduler": "^0.27.0"
  },
  "devDependencies": {
    "@expo/cli": "~54.0.16",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/expo": "^22.7.1",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.1",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "metro-config": "~0.83.0",
    "metro-resolver": "~0.83.0",
    "mongodb-memory-server": "^10.1.4",
    "nx": "^22.7.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
