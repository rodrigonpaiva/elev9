{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "api-client",
  "projectType": "library",
  "sourceRoot": "packages/api-client/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/run-node-cli.js node_modules/typescript/bin/tsc -p packages/api-client/tsconfig.json"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/api-client",
        "command": "node ../../scripts/run-node-cli.js ../../node_modules/eslint/bin/eslint.js src --ext .ts,.d.ts --config ../../.eslintrc.cjs"
      }
    }
  }
}
