{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "types",
  "projectType": "library",
  "sourceRoot": "packages/types/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/types/tsconfig.json"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/types",
        "command": "eslint src --ext .ts,.d.ts --config ../../.eslintrc.cjs"
      }
    }
  }
}
